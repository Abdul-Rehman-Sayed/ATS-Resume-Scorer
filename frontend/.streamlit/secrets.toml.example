# Template for Streamlit Community Cloud secrets.
# On Streamlit Cloud: App -> Settings -> Secrets -> paste the filled-in version.
# Do NOT commit a real secrets.toml (it is gitignored).

[backend]
# Public URL of your deployed FastAPI backend (Hugging Face Space / Render / etc.)
url = "https://YOUR-BACKEND-URL"

[supabase]
SUPABASE_URL = "https://YOUR-PROJECT.supabase.co"
SUPABASE_ANON_KEY = "YOUR-SUPABASE-ANON-KEY"

[google_oauth]
# Your deployed Streamlit app URL (where Google sends users back after login)
redirect_uri = "https://YOUR-APP.streamlit.app"
